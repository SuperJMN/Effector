<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Clear parent sources so Effector submodule projects only see nuget.org.
         They don't reference the Effector NuGet package (project references are used instead),
         so superjmn-github is not needed here and would trigger NU1507 without mapping. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
